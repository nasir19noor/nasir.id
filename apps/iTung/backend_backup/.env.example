# Backend Environment Variables

# ============================================================
# AWS S3 Configuration
# ============================================================
# Required for image upload functionality

# AWS Access credentials (IAM user)
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# AWS region where your S3 bucket is located
AWS_REGION=ap-southeast-1

# S3 bucket name for storing images and avatars
S3_BUCKET_NAME=assets.itung.nasir.id

# CDN/CloudFront base URL for accessing uploaded files
# If empty, defaults to https://{S3_BUCKET_NAME}.s3.amazonaws.com
S3_CDN_BASE=https://assets.itung.nasir.id

# ============================================================
# AI/LLM Configuration
# ============================================================

# Claude API key (Anthropic)
ANTHROPIC_API_KEY=your_claude_api_key_here

# Google Gemini API key (for image generation)
GOOGLE_API_KEY=your_google_gemini_api_key_here

# ============================================================
# Avatar Generation Configuration
# ============================================================

# HuggingFace API token for cartoon/avatar generation
HF_TOKEN=your_huggingface_token_here

# ============================================================
# Database Configuration
# ============================================================

# PostgreSQL connection string (if using PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/iTung

# ============================================================
# Application Configuration
# ============================================================

# Set to "development", "staging", or "production"
ENVIRONMENT=development

# Server host and port (usually handled by deployment)
# HOST=0.0.0.0
# PORT=9000
