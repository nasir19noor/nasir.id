# Copy to .env and fill in from your Terraform outputs.
# Astro exposes only PUBLIC_-prefixed vars to the browser; they are
# inlined at build time, so rebuild whenever they change.

PUBLIC_API_BASE_URL=
PUBLIC_AWS_REGION=ap-southeast-1
PUBLIC_COGNITO_USER_POOL_ID=
PUBLIC_COGNITO_USER_POOL_CLIENT_ID=
