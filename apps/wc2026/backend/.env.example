# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/wc2026

# Public ESPN scoreboard endpoint for the FIFA World Cup.
# We pass a date range each hour. No API key required.
ESPN_SCOREBOARD_URL=https://site.api.espn.com/apis/site/v2/sports/soccer/fifa.world/scoreboard

# How often to refresh scores from ESPN (minutes).
REFRESH_INTERVAL_MIN=60

# CORS — comma-separated list. The frontend domain.
CORS_ORIGINS=https://wc2026.nasir.id,http://localhost:5002

# Run env
ENVIRONMENT=production

# Admin credentials — protect the /admin/* endpoints with HTTP Basic auth.
# The frontend's /admin page logs in with these. Pick a strong password.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# Visitor geolocation — resolve country from IP for analytics.
# Free service, no key required. Set ENABLED=false to disable lookups.
GEO_LOOKUP_ENABLED=true
GEO_LOOKUP_URL=http://ip-api.com/json
GEO_LOOKUP_TIMEOUT=2.5

# ── AI predictions (Claude) ────────────────────────────────────────
# Claude API key (Anthropic). Required for the daily prediction job.
ANTHROPIC_API_KEY=your_claude_api_key_here
# Model. Default is sensible; override if needed.
PREDICTION_MODEL=claude-opus-4-8
# Run every 6 hours at these WIB hours (comma-separated), on the minute below.
PREDICTION_HOURS=0,6,12,18
PREDICTION_MINUTE=0
# Predict every scheduled fixture kicking off within this many hours.
PREDICTION_WINDOW_HOURS=24

# ── Player stats enrichment (API-Football) ──────────────────────────
# One-time backfill (POST /admin/enrich-stats-af) for tackles, interceptions,
# duels, dribbles, passes, fouls, minutes and rating — metrics ESPN doesn't
# provide. Free tier: sign up at https://dashboard.api-football.com/register
# (no payment info required), ~100 requests/day. Leave unset to skip.
API_FOOTBALL_KEY=
