---
interface Props { title: string }
const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta name="description" content="Read-only infrastructure copilot for the Contabo VPS and AWS account." />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans+Condensed:wght@600&family=IBM+Plex+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* Instrument-panel palette: cool, printed, non-decorative.
     Every colour below earns its place — signal blue means "the machine is
     acting", teal means healthy, rust means refused. */
  :root {
    --paper: #eef1f6;
    --panel: #ffffff;
    --ink: #12161d;
    --dim: #5a6478;
    --rule: #c9d3e0;
    --signal: #1f3fe0;
    --ok: #0f8a78;
    --alert: #a8321e;

    --sans: 'IBM Plex Sans', ui-sans-serif, system-ui, sans-serif;
    --cond: 'IBM Plex Sans Condensed', var(--sans);
    --mono: 'IBM Plex Mono', ui-monospace, 'SF Mono', monospace;

    --col: 62rem;
    --r: 3px;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --paper: #0f131a;
      --panel: #161c26;
      --ink: #e5eaf3;
      --dim: #8d97a9;
      --rule: #29323f;
      --signal: #7b93ff;
      --ok: #34c6ac;
      --alert: #ff8570;
    }
  }

  *, *::before, *::after { box-sizing: border-box; }

  html, body {
    margin: 0;
    height: 100%;
  }

  body {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--sans);
    font-size: 15px;
    line-height: 1.55;
    -webkit-font-smoothing: antialiased;
  }

  :focus-visible {
    outline: 2px solid var(--signal);
    outline-offset: 2px;
  }

  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.001ms !important;
      transition-duration: 0.001ms !important;
    }
  }
</style>
