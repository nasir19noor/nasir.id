# --- Bedrock / AWS ---
AWS_REGION=ap-southeast-1
# IMPORTANT: verify the exact model ID / inference profile in the Bedrock console.
# APAC cross-region inference profiles are usually prefixed with "apac."
BEDROCK_MODEL_ID=apac.anthropic.claude-sonnet-4-20250514-v1:0
AWS_ACCESS_KEY_ID=your-agent-key
AWS_SECRET_ACCESS_KEY=your-agent-secret

# --- PostgreSQL (already on your VPS) ---
DATABASE_URL=postgresql://agent:password@localhost:5432/agent

# --- Agent behaviour ---
MAX_TOKENS=2048
MAX_AGENT_STEPS=10
SHELL_ALLOWLIST=ls,cat,df,free,uptime,systemctl status,docker ps,git status,git log,tail
