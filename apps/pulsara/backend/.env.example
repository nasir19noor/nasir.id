# Database
DATABASE_URL=postgresql://user:password@localhost:5432/pulsara

# Redis
REDIS_URL=redis://localhost:6379

# Threads API
THREADS_CLIENT_ID=your_client_id
THREADS_CLIENT_SECRET=your_client_secret
# Long-lived access token — get from Meta Developer Portal (graph.threads.net)
THREADS_ACCESS_TOKEN=your_threads_access_token

# JWT
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_REGION=us-east-1

# AWS S3 (for media storage)
AWS_BUCKET_NAME=your_bucket_name

# AWS Bedrock
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_INFERENCE_PROFILE_ID=your_inference_profile_id
BEDROCK_INFERENCE_PROFILE_ARN=your_inference_profile_arn
BEDROCK_REGION=us-east-1

# Google Vertex AI (for AI image generation)
VERTEX_PROJECT_ID=your_gcp_project_id
VERTEX_LOCATION=us-central1
VERTEX_IMAGE_MODEL=imagen-3.0-generate-001
# Base64-encoded GCP service account JSON key (run: base64 -w0 key.json on Linux/Mac, or certutil -encode key.json on Windows)
GOOGLE_APPLICATION_CREDENTIALS_JSON=base64_encoded_string_here

# Environment
ENVIRONMENT=development